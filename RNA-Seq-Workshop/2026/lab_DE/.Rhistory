title="GO Enrichment - Down", x="GeneRatio")
dn_dp + aes(y = Description)
?enricher
# GO enrichment and
up_enrich <- enricher(up, universe=out$Gene, TERM2GENE=go,
pvalueCutoff = 0.2)
up_enrich@result$Description <- Term(GOTERM[up_enrich@result$ID])
up_dp <- dotplot(up_enrich, showCategory=10,
title="GO Enrichment - UP", x="GeneRatio")
up_dp + aes(y = Description)
