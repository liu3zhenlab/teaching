go <- read.delim("https://raw.githubusercontent.com/liu3zhenlab/teaching/refs/heads/master/RNA-Seq-Workshop/2026/lab_DE/data/go.txt", header=F)
colnames(go) <- c("Gene", "GO")
go <- go[, c("GO", "Gene")] # switch gene and GO
is_go_valid <- go$GO %in% keys(GOTERM)
go <- go[is_go_valid, ]
# DEG
up <- out$Gene[out$padj < 0.05 & out$log2FoldChange > 0]
dn <- out$Gene[out$padj < 0.05 & out$log2FoldChange < 0]
# GO enrichment and
up_enrich <- enricher(up,  universe=out$Gene, TERM2GENE=go)
up_enrich@result$Description <- Term(GOTERM[up_enrich@result$ID])
up_dp <- dotplot(up_enrich, showCategory=10,
title="GO Enrichment - UP", x="GeneRatio")
up_dp + aes(y = Description)
up
